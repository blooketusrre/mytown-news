---
layout: base.njk
pageTitle: "My Town News — SF Neighborhood News, Every Friday"
pageDesc: "Free, independent hyperlocal news for every San Francisco neighborhood. Published every Friday."
---

{# ── Hero ──────────────────────────────────────────────────────────────── #}
<header class="masthead home-hero" role="banner">
  <div class="container">
    <p class="home-hero__eyebrow">San Francisco · Free &amp; Independent · Every Friday</p>
    <h1 class="home-hero__title">My Town <em>News</em></h1>
    <p class="home-hero__desc">
      Hyperlocal news for every San Francisco neighborhood — sourced, verified, and delivered to your door every Friday.
    </p>
  </div>
  <div class="gold-rule"></div>
</header>

{# ── Sticky nav ────────────────────────────────────────────────────────── #}
<nav class="site-nav" aria-label="Site navigation">
  <div class="site-nav__inner container">
    <ul class="site-nav__links" role="list">
      <li><a href="#neighborhoods">Neighborhoods</a></li>
      <li><a href="#this-week">This Week</a></li>
      <li><a href="#newsletter">Newsletter</a></li>
      <li><a href="/about/">About</a></li>
    </ul>
    <span class="site-nav__meta">mytown.news</span>
  </div>
</nav>

<main id="main">

  {# ── Cluster Map Section ─────────────────────────────────────────────── #}
  <section id="neighborhoods" class="cluster-map-section" aria-labelledby="map-heading">
    <div class="container">
      <div class="cluster-map-section__intro">
        <h2 class="cluster-map-section__title" id="map-heading">Find Your Neighborhood</h2>
        <p class="cluster-map-section__sub">Click your part of the city or type your ZIP code below.</p>
      </div>

      <div class="cluster-map-wrap">

        {# ── Real Leaflet Map (OpenStreetMap) ────────────────────────── #}
        <div>
          <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
          <div id="sf-map" style="height:480px;border-radius:6px;border:1px solid var(--rule);overflow:hidden;" aria-label="San Francisco neighborhood map"></div>
          <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
          <script>
          (function() {
            var map = L.map('sf-map', {
              center: [37.766, -122.435],
              zoom: 12,
              scrollWheelZoom: false,
              zoomControl: true
            });

            L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
              attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/">CARTO</a>',
              subdomains: 'abcd',
              maxZoom: 16
            }).addTo(map);

            var clusters = [
              { slug:'north-waterfront', name:'North Waterfront', lat:37.806, lng:-122.413, color:'#c8943a', live:true,  url:'/north-waterfront/', hoods:'North Beach · Telegraph Hill · Fisherman\'s Wharf' },
              { slug:'marina',           name:'Marina & Pac. Heights', lat:37.799, lng:-122.436, color:'#2a9d8f', live:false, hoods:'Marina · Cow Hollow · Pacific Heights' },
              { slug:'presidio-richmond',name:'Presidio & Richmond',   lat:37.778, lng:-122.468, color:'#2d6a4f', live:false, hoods:'Presidio · Inner & Outer Richmond' },
              { slug:'russian-nob',      name:'Russian Hill & Nob Hill', lat:37.793, lng:-122.415, color:'#8b2635', live:false, hoods:'Russian Hill · Nob Hill · Polk Gulch' },
              { slug:'downtown',         name:'Downtown & Embarcadero', lat:37.787, lng:-122.397, color:'#1e4a8a', live:false, hoods:'Financial District · Chinatown · Jackson Square' },
              { slug:'civic',            name:'Civic Center & Hayes',   lat:37.776, lng:-122.421, color:'#6b3fa0', live:false, hoods:'Civic Center · Hayes Valley · Tenderloin' },
              { slug:'soma',             name:'SoMa & Mission Bay',     lat:37.772, lng:-122.394, color:'#c05928', live:false, hoods:'SoMa · Mission Bay · Rincon Hill' },
              { slug:'haight',           name:'Haight & Cole Valley',   lat:37.769, lng:-122.449, color:'#b8860b', live:false, hoods:'Haight-Ashbury · Cole Valley · Duboce Triangle' },
              { slug:'castro',           name:'Castro & Noe Valley',    lat:37.757, lng:-122.432, color:'#b5334a', live:false, hoods:'Castro · Noe Valley · Glen Park' },
              { slug:'mission',          name:'Mission & Bernal Hts',   lat:37.748, lng:-122.418, color:'#c4442a', live:false, hoods:'Mission · Bernal Heights · Potrero Hill' },
              { slug:'sunset',           name:'The Sunset',             lat:37.756, lng:-122.483, color:'#3d6b8f', live:false, hoods:'Inner Sunset · Outer Sunset · West Portal' },
              { slug:'bayview',          name:'Bayview & Excelsior',    lat:37.726, lng:-122.397, color:'#6b8c3a', live:false, hoods:'Bayview · Excelsior · Visitacion Valley' }
            ];

            clusters.forEach(function(c) {
              var radius = c.live ? 16 : 11;
              var marker = L.circleMarker([c.lat, c.lng], {
                radius: radius,
                fillColor: c.live ? c.color : '#b0aaa4',
                color: '#fff',
                weight: 2,
                opacity: 1,
                fillOpacity: c.live ? 0.92 : 0.55
              }).addTo(map);

              var label = '<strong>' + c.name + '</strong><br><span style="font-size:0.8em;color:#666">' + c.hoods + '</span>';
              if (!c.live) label += '<br><em style="font-size:0.75em;color:#999">Coming soon</em>';
              marker.bindTooltip(label, { sticky: true, direction: 'top', offset: [0, -8] });

              if (c.live) {
                marker.getElement() && (marker.getElement().style.cursor = 'pointer');
                marker.on('click', function() { window.location.href = c.url; });
                marker.on('add', function() {
                  var el = marker.getElement();
                  if (el) el.style.cursor = 'pointer';
                });
              }
            });
          })();
          </script>
        </div>

        {# ── Cluster list + ZIP lookup ──────────────────────────────── #}
        <div>
          <nav class="cluster-list" aria-label="Neighborhood clusters">
            {% for c in clusters %}
            {% if c.live %}
            <a class="cluster-list__item" href="/{{ c.slug }}/"
               data-cluster="{{ c.slug }}"
               aria-label="{{ c.name }}: {{ c.neighborhoods | join(', ') }}">
              <span class="cluster-list__dot" style="background:{{ c.accent }}"></span>
              <div>
                <div class="cluster-list__name">{{ c.name }}</div>
                <div class="cluster-list__hoods">{{ c.neighborhoods | join(' · ') }}</div>
              </div>
              <span class="cluster-list__badge" style="background:{{ c.accent }}">Live</span>
            </a>
            {% else %}
            <div class="cluster-list__item" style="cursor:default;opacity:0.55"
                 data-cluster="{{ c.slug }}">
              <span class="cluster-list__dot" style="background:{{ c.accent }}"></span>
              <div>
                <div class="cluster-list__name">{{ c.name }}</div>
                <div class="cluster-list__hoods">{{ c.neighborhoods | join(' · ') }}</div>
              </div>
              <span style="font-family:var(--font-ui);font-size:0.5625rem;color:var(--muted);letter-spacing:0.08em;">Soon</span>
            </div>
            {% endif %}
            {% endfor %}
          </nav>

          {# ZIP lookup #}
          <div class="zip-lookup">
            <label class="zip-lookup__label" for="zip-input">Find by ZIP code</label>
            <div class="zip-lookup__row">
              <input class="zip-lookup__input" id="zip-input" type="text"
                     inputmode="numeric" pattern="[0-9]{5}"
                     maxlength="5" placeholder="e.g. 94133" aria-label="Enter SF ZIP code">
              <button class="zip-lookup__btn" id="zip-btn" type="button">Go</button>
            </div>
            <div class="zip-lookup__result" id="zip-result" role="status" aria-live="polite"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  {# ── This Week — Editor's Picks ──────────────────────────────────────── #}
  <section id="this-week" class="editors-picks" aria-labelledby="picks-heading">
    <div class="container">
      <div class="section-head">
        <h2 class="section-head__label" id="picks-heading">This Week — Editor's Picks</h2>
        <span class="section-head__line" aria-hidden="true"></span>
      </div>

      {# Feature the live cluster's top story #}
      {% if northWaterfront %}
      <div class="top-stories" style="grid-template-columns:2fr 1fr">
        <article class="story-main">
          <span class="nbadge" style="--accent:#c8943a;border-color:#c8943a;color:#c8943a">North Waterfront</span>
          <p class="tag" style="color:#c8943a">{{ northWaterfront.topStories[0].tag }}</p>
          <h3 style="font-family:var(--font-head);font-size:clamp(1.25rem,2.2vw,1.75rem);font-weight:900;line-height:1.18;margin-bottom:12px;letter-spacing:-0.02em">
            {{ northWaterfront.topStories[0].headline }}
          </h3>
          <p class="byline">{{ northWaterfront.topStories[0].byline }} · {{ northWaterfront.topStories[0].date }}</p>
          <p style="font-size:var(--text-md);line-height:1.7;color:var(--text)">
            {{ northWaterfront.topStories[0].body | truncate(350) }}
          </p>
          <a href="/north-waterfront/" style="display:inline-flex;align-items:center;gap:6px;font-family:var(--font-ui);font-size:var(--text-xs);font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#c8943a;text-decoration:none;margin-top:16px;border-bottom:1px solid #c8943a">
            Read the full North Waterfront issue →
          </a>
        </article>

        <div class="story-side" style="display:flex;flex-direction:column;gap:24px">
          {% for s in northWaterfront.topStories.slice(1) %}
          <article>
            <span class="nbadge" style="--accent:#c8943a;border-color:#c8943a;color:#c8943a">{{ s.neighborhood }}</span>
            <h3 style="font-family:var(--font-head);font-size:1rem;font-weight:700;line-height:1.3;margin-top:4px;margin-bottom:8px">{{ s.headline }}</h3>
            <p class="byline">{{ s.date }}</p>
            <p style="font-size:var(--text-sm);line-height:1.65;color:var(--muted)">{{ s.body | truncate(160) }}</p>
          </article>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      {# Placeholder cards for coming clusters #}
      <div style="margin-top:40px">
        <div class="section-head">
          <h2 class="section-head__label">More Clusters Coming Soon</h2>
          <span class="section-head__line"></span>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px">
          {% for c in clusters %}
          {% if not c.live %}
          <div style="background:white;border:1px solid var(--rule);border-radius:var(--radius);padding:20px;border-top:3px solid {{ c.accent }}">
            <p style="font-family:var(--font-ui);font-size:var(--text-xs);font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:{{ c.accent }};margin-bottom:6px">Coming Soon</p>
            <h3 style="font-family:var(--font-head);font-size:1rem;font-weight:700;margin-bottom:6px">{{ c.name }}</h3>
            <p style="font-family:var(--font-ui);font-size:var(--text-xs);color:var(--muted);line-height:1.5">{{ c.neighborhoods | join(' · ') }}</p>
          </div>
          {% endif %}
          {% endfor %}
        </div>
      </div>

    </div>
  </section>

  {# ── Newsletter ───────────────────────────────────────────────────────── #}
  <section id="newsletter" aria-labelledby="newsletter-heading">
    <div class="container">
      <div class="newsletter">
        <p class="newsletter__eyebrow">Free. Independent. Weekly.</p>
        <h2 class="newsletter__headline" id="newsletter-heading">Get My Town News<br>every Friday morning</h2>
        <p class="newsletter__sub">
          Neighborhood news, events, and your local directory — for every SF cluster, every week.
        </p>
        <form class="newsletter__form" aria-label="Newsletter signup">
          <input class="newsletter__input" type="email" placeholder="your@email.com" required aria-label="Email address">
          <button class="newsletter__btn" type="submit">Subscribe</button>
        </form>
        <p class="newsletter__note">No ads. No spam. Unsubscribe anytime.</p>
      </div>
    </div>
  </section>

</main>

{% include "partials/footer.njk" %}

<script src="/assets/js/cluster-map.js"></script>
